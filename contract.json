{
  "service": "shre-chat",
  "version": "1.0",
  "port": 5510,
  "protocol": "https",
  "description": "Web-based chat interface \u2014 proxies to shre-router, manages sessions, suggestions, voice, tasks, reports, and notifications",
  "endpoints": {
    "GET /api/health": {
      "returns": "HealthResponse",
      "auth": false,
      "description": "Liveness check"
    },
    "POST /api/auth/login": {
      "accepts": {
        "username": "string",
        "password": "string"
      },
      "returns": "AuthResult",
      "auth": false,
      "description": "User login"
    },
    "GET /api/auth/check": {
      "returns": "{ authenticated: boolean }",
      "auth": false,
      "description": "Check authentication status"
    },
    "POST /api/verify-identity": {
      "accepts": {
        "code": "string"
      },
      "returns": "{ verified: boolean }",
      "auth": false,
      "description": "Identity verification gate via vault"
    },
    "POST /api/router/v1/chat": {
      "accepts": "ChatRequest",
      "returns": "SSE Stream",
      "auth": true,
      "description": "Chat proxy to shre-router (SSE streaming)"
    },
    "POST /api/cli/chat": {
      "accepts": "ChatRequest",
      "returns": "SSE Stream",
      "auth": true,
      "description": "CLI chat endpoint"
    },
    "GET /api/sessions/:agentId": {
      "returns": "Session[]",
      "auth": true,
      "description": "List chat sessions for an agent"
    },
    "GET /api/sessions/:agentId/:sessionId": {
      "returns": "Session",
      "auth": true,
      "description": "Get a specific chat session with messages"
    },
    "POST /api/sessions/:agentId/:sessionId/compact": {
      "returns": "{ ok: boolean }",
      "auth": true,
      "description": "Compact a session (summarize old messages)"
    },
    "GET /api/search": {
      "returns": "SearchResult[]",
      "auth": true,
      "description": "Search across chat sessions"
    },
    "GET /api/feed": {
      "returns": "FeedItem[]",
      "auth": true,
      "description": "Activity feed"
    },
    "GET /api/agents": {
      "returns": "Agent[]",
      "auth": true,
      "description": "List available agents"
    },
    "GET /api/agent-workspace": {
      "returns": "AgentWorkspaceSummary",
      "auth": true,
      "description": "Read-only Hermes/OpenClaw/CLI workspace summary for the conversation cockpit"
    },
    "GET /api/agent-workspace/cli-sessions/:id/resume": {
      "returns": "AgentWorkspaceResumePayload",
      "auth": true,
      "description": "Build a safe UI continuation payload from an existing CLI ledger"
    },
    "GET /api/agent-workspace/orchestration-runs": {
      "returns": "{ runs: AgentWorkspaceOrchestrationRun[] }",
      "auth": true,
      "description": "List persisted multi-model orchestration runs and plan DAG status"
    },
    "POST /api/agent-workspace/orchestration-runs": {
      "accepts": {
        "title": "string",
        "objective": "string",
        "nodes": "PlanNode[]"
      },
      "returns": "{ ok: boolean, run: AgentWorkspaceOrchestrationRun }",
      "auth": true,
      "description": "Persist a gated plan DAG for deterministic multi-executor orchestration"
    },
    "GET /api/agent-workspace/orchestration-runs/:id": {
      "returns": "{ run: AgentWorkspaceOrchestrationRun }",
      "auth": true,
      "description": "Fetch one orchestration run with recent canonical events"
    },
    "POST /api/agent-workspace/orchestration-runs/:id/events": {
      "accepts": "CanonicalEvent",
      "returns": "{ ok: boolean, event: CanonicalEvent }",
      "auth": true,
      "description": "Append a normalized Claude, Codex, OpenClaw, local, or training event to a run"
    },
    "POST /api/agent-workspace/orchestration-runs/:id/executor-events": {
      "accepts": "{ executor?: string, nodeId?: string, event?: object, events?: object[] }",
      "returns": "{ ok: boolean, events: CanonicalEvent[] }",
      "auth": true,
      "description": "Bridge shre-terminal/OpenClaw normalized events into the canonical orchestration event schema"
    },
    "POST /api/agent-workspace/orchestration-runs/:id/training-jobs": {
      "accepts": {
        "nodeId": "string",
        "datasetRef": "string",
        "targetMetric": "number",
        "metricName": "string"
      },
      "returns": "{ ok: boolean, job: AgentWorkspaceTrainingJob }",
      "auth": true,
      "description": "Queue a batch training job under a run without blocking the conversation loop"
    },
    "POST /api/agent-workspace/orchestration-runs/:id/training-jobs/:jobId/transition": {
      "accepts": {
        "status": "queued | running | checkpoint | evaluating | succeeded | failed",
        "step": "number",
        "metric": "number"
      },
      "returns": "{ ok: boolean, job: AgentWorkspaceTrainingJob }",
      "auth": true,
      "description": "Advance a training job lifecycle and append canonical training progress events"
    },
    "GET /api/agent-workspace/training-candidates": {
      "returns": "{ candidates: AgentWorkspaceCandidate[] }",
      "auth": true,
      "description": "List staged trace-to-skill training candidates"
    },
    "POST /api/agent-workspace/training-candidates": {
      "accepts": {
        "sessionId": "string",
        "proposedSkillPath": "string",
        "notes": "string"
      },
      "returns": "{ ok: boolean, candidate: AgentWorkspaceCandidate }",
      "auth": true,
      "description": "Stage a CLI/session trace as a skill candidate; does not promote or fine-tune"
    },
    "GET /api/agent-workspace/approval-policy": {
      "returns": "ApprovalPolicySummary",
      "auth": true,
      "description": "Read the workspace approval-gate invariant for public, financial, irreversible, and external-write actions"
    },
    "GET /api/agent-workspace/approval-cards": {
      "returns": "{ cards: AgentWorkspaceApprovalCard[] }",
      "auth": true,
      "description": "List pending and recently decided approval cards for gated workspace actions"
    },
    "POST /api/agent-workspace/approval-cards": {
      "accepts": {
        "title": "string",
        "actionType": "public | financial | irreversible | pos_write | listing_publish | customer_message",
        "summary": "string",
        "requestedBy": "string",
        "sessionId": "string",
        "risk": "low | medium | high | critical",
        "payload": "object"
      },
      "returns": "{ ok: boolean, card: AgentWorkspaceApprovalCard }",
      "auth": true,
      "description": "Create an approval card; execution remains blocked until an approved card is consumed by a trusted executor"
    },
    "POST /api/agent-workspace/approval-cards/:id/approve": {
      "accepts": {
        "decidedBy": "string",
        "note": "string"
      },
      "returns": "{ ok: boolean, card: AgentWorkspaceApprovalCard }",
      "auth": true,
      "description": "Approve a pending approval card without executing the underlying side effect"
    },
    "POST /api/agent-workspace/approval-cards/:id/reject": {
      "accepts": {
        "decidedBy": "string",
        "note": "string"
      },
      "returns": "{ ok: boolean, card: AgentWorkspaceApprovalCard }",
      "auth": true,
      "description": "Reject a pending approval card"
    },
    "POST /api/model": {
      "accepts": {
        "model": "string"
      },
      "returns": "{ ok: boolean }",
      "auth": true,
      "description": "Switch active model"
    },
    "GET /api/model": {
      "returns": "{ model: string }",
      "auth": true,
      "description": "Get current model"
    },
    "POST /api/transcribe": {
      "accepts": "audio/webm",
      "returns": "{ text: string }",
      "auth": true,
      "description": "Speech-to-text via shre-router/Whisper"
    },
    "POST /api/tts": {
      "accepts": {
        "text": "string"
      },
      "returns": "audio/mpeg",
      "auth": true,
      "description": "Text-to-speech"
    },
    "POST /api/tts/stream": {
      "accepts": {
        "text": "string"
      },
      "returns": "SSE audio stream",
      "auth": true,
      "description": "Streaming text-to-speech"
    },
    "POST /api/run": {
      "accepts": "RunRequest",
      "returns": "RunResult",
      "auth": true,
      "description": "Execute a run (task delegation)"
    },
    "GET /api/contacts/search": {
      "returns": "Contact[]",
      "auth": true,
      "description": "Search contacts (proxy to shre-contacts)"
    },
    "POST /api/share": {
      "accepts": {
        "sessionId": "string",
        "agentId": "string"
      },
      "returns": "{ shareId: string, url: string }",
      "auth": true,
      "description": "Create a shareable link for a chat session"
    },
    "GET /api/share/:shareId": {
      "returns": "SharedSession",
      "auth": false,
      "description": "View a shared chat session"
    },
    "GET /api/costs/:path": {
      "returns": "CostData",
      "auth": true,
      "description": "Cost data proxy to shre-meter"
    },
    "GET /api/task-timeline": {
      "returns": "TaskTimeline",
      "auth": true,
      "description": "Task timeline proxy to shre-tasks"
    },
    "WS /ws/terminal": {
      "returns": "PTY stream",
      "auth": true,
      "description": "WebSocket terminal (PTY)"
    },
    "WS /ws/notifications": {
      "returns": "JSON notifications",
      "auth": true,
      "description": "WebSocket notification stream (reminders, status updates)"
    }
  },
  "events": {
    "publishes": [
      {
        "type": "task.complete",
        "schema": {
          "sessionId": "string",
          "agentId": "string"
        }
      },
      {
        "type": "reminder.due",
        "schema": {
          "reminders": "Reminder[]"
        }
      }
    ],
    "subscribes": []
  },
  "cortex_types": [],
  "depends_on": {
    "services": [
      "shre-router",
      "sqlite"
    ],
    "optional": [
      "shre-tasks",
      "shre-fleet",
      "shre-meter",
      "shre-contacts",
      "router-gateway",
      "redis"
    ]
  },
  "health": {
    "liveness": "GET /api/health",
    "readiness": "GET /api/health",
    "response": {
      "status": "string",
      "service": "string",
      "port": "number"
    }
  }
}
