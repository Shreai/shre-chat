# Copy to your CI secret store or local shell export before running RBAC matrix tests.

# Required if E2E_RBAC_REQUIRE_ALL=true
E2E_SUPERADMIN_USER=
E2E_SUPERADMIN_PASS=
E2E_ADMIN_USER=
E2E_ADMIN_PASS=
E2E_OPERATOR_USER=
E2E_OPERATOR_PASS=
E2E_READONLY_USER=
E2E_READONLY_PASS=

# Optional strictness toggle:
# - false (default): missing credentials => role test skipped
# - true: missing credentials => role test fails
E2E_RBAC_REQUIRE_ALL=false

# Stage and target base URL
SHRE_STAGE=dev
PLAYWRIGHT_BASE_URL=http://127.0.0.1:5000
