node_modules/
dist/
release/
*.tsbuildinfo
.DS_Store
chat.db

# Playwright visual regression: commit baseline PNGs, ignore diffs
# (diffs land in e2e/__screenshots__/*-diff.png when a test fails)
e2e/__screenshots__/**/*-diff.png
e2e/__screenshots__/**/*-actual.png

# Playwright — run artifacts and reports
# e2e/results/.gitkeep is tracked so the dir exists for reporters to write into.
e2e/results/artifacts/
e2e/results/html-report/
e2e/results/test-results.json
e2e/results/failed-tests.json
e2e/results/qa-report.md
e2e/results/latest-*.json
e2e/results/stages/*.json
graphify-out/
playwright-report/
test-results/
playwright/.cache/
