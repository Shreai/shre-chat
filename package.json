{
  "name": "shre-chat",
  "version": "1.0.29",
  "private": true,
  "description": "AROS — AI-powered retail chat assistant",
  "main": "electron/dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5000 --host 0.0.0.0",
    "build": "vite build",
    "lint": "eslint src/ --max-warnings=9999",
    "lint:fix": "eslint src/ --fix --max-warnings=9999",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "prepare": "husky",
    "test": "vitest run",
    "serve": "node serve.js",
    "preview": "vite preview --port 5510",
    "build:electron": "tsc -p electron/tsconfig.json && cp electron/dist/main.js electron/dist/main.cjs",
    "build:all": "vite build && tsc -p electron/tsconfig.json && cp electron/dist/main.js electron/dist/main.cjs",
    "build:app": "vite build && tsc -p electron/tsconfig.json && cp electron/dist/main.js electron/dist/main.cjs && electron-builder",
    "start:app": "tsc -p electron/tsconfig.json && cp electron/dist/main.js electron/dist/main.cjs && electron .",
    "test:e2e": "npx playwright test",
    "test:visual": "npx playwright test --project=visual-regression",
    "test:visual:update": "npx playwright test --project=visual-regression --update-snapshots",
    "qa": "node scripts/qa-orchestrator.mjs",
    "qa:rerun": "node scripts/qa-orchestrator.mjs --rerun-failed",
    "qa:agent": "node scripts/qa-orchestrator.mjs --agent",
    "qa:report": "node scripts/qa-orchestrator.mjs --report-only",
    "qa:dry": "node scripts/qa-orchestrator.mjs --dry-run",
    "test:android": "node scripts/test-android.mjs",
    "test:android:smoke": "node scripts/test-android.mjs --agent smoke",
    "test:android:manual": "node scripts/test-android.mjs --manual"
  },
  "build": {
    "appId": "ai.shre.chat",
    "productName": "AROS",
    "icon": "src/assets/icon.icns",
    "mac": {
      "target": "dir",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "icon": "src/assets/icon.icns"
    },
    "files": [
      "electron/dist/**/*",
      "dist/**/*",
      "serve.js"
    ],
    "extraResources": [
      {
        "from": "serve.js",
        "to": "serve.js"
      }
    ],
    "extraMetadata": {
      "main": "electron/dist/main.cjs"
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shre/ui-kit": "file:./stubs/shre-ui-kit",
    "@tanstack/react-virtual": "^3.13.22",
    "@types/dompurify": "^3.0.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "emoji-mart": "^5.6.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.10.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "partysocket": "^1.1.16",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shre-sdk": "file:../shre-sdk",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "xterm": "^5.3.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "node-pty": "^1.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "ws": "^8.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty",
      "esbuild"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --quiet",
      "prettier --write"
    ],
    "src/**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
